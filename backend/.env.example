# =====================================================
# Influencer AI Backend — Environment Variables
# =====================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Both keys are OPTIONAL — the app runs without them
# using rule-based fallbacks and mock/simulated data.
# =====================================================

# OpenRouter API key (for AI-powered influencer reviews)
# Get one free at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Apify API key (for live Instagram/YouTube scraping)
# Get one free at: https://console.apify.com/account/integrations
APIFY_API_KEY=apify_api_your-key-here
